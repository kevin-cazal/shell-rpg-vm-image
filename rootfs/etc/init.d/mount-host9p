#!/sbin/openrc-run
# Mount virtio-9p export at /mnt/host (tag host9p). Retries until the device is up.

depend() {
	need localmount
	before game-ram-setup
}

start() {
	ebegin "Mount host9p at /mnt/host"

	if mountpoint -q /mnt/host 2>/dev/null; then
		eend 0
		return 0
	fi

	modprobe 9pnet_virtio 2>/dev/null
	modprobe 9p 2>/dev/null

	_tries=0
	while [ "$_tries" -lt 60 ]; do
		if mount -t 9p -o trans=virtio,version=9p2000.L host9p /mnt/host 2>/dev/null; then
			eend 0
			return 0
		fi
		sleep 1
		_tries=$((_tries + 1))
	done

	ewarn "host9p mount failed (no virtio-9p device yet)"
	eend 0
	return 0
}

stop() {
	need_stop=no
}
